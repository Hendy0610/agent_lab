[Unit]
Description=Agent Lab Telegram Webhook Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/agent-lab-bot
EnvironmentFile=/opt/agent-lab-bot/.env
ExecStart=/opt/agent-lab-bot/venv/bin/uvicorn webhook_server:app --host 0.0.0.0 --port 8443
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
